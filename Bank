<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BNA - National Agricultural Bank</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .gradient-bg {
            background: linear-gradient(135deg, #2c7744 0%, #5aaf6a 100%);
        }
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        .transaction-animation {
            transition: all 0.3s ease;
        }
        .transaction-animation:hover {
            background-color: #f3f4f6;
        }
        .nav-item {
            position: relative;
        }
        .nav-item::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: #2c7744;
            transition: width 0.3s ease;
        }
        .nav-item:hover::after {
            width: 100%;
        }
    </style>
</head>
<body class="bg-gray-50 font-sans">
    <!-- Header -->
    <header class="gradient-bg text-white shadow-lg">
        <div class="container mx-auto px-4 py-3">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-2">
                    <i class="fas fa-leaf text-3xl"></i>
                    <h1 class="text-2xl font-bold">National Agricultural Bank</h1>
                </div>
                <div class="hidden md:flex items-center space-x-6">
                    <a href="#" class="nav-item text-white hover:text-green-100 py-2">Home</a>
                    <a href="#" class="nav-item text-white hover:text-green-100 py-2">Accounts</a>
                    <a href="#" class="nav-item text-white hover:text-green-100 py-2">Transfers</a>
                    <a href="#" class="nav-item text-white hover:text-green-100 py-2">Loans</a>
                    <a href="#" class="nav-item text-white hover:text-green-100 py-2">Support</a>
                </div>
                <div class="flex items-center space-x-4">
                    <button class="bg-white text-green-700 px-4 py-2 rounded-full font-semibold hover:bg-green-50 transition" id="login-btn">
                        Login
                    </button>
                    <button class="md:hidden text-white text-2xl" id="mobile-menu-button">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Mobile Menu -->
        <div class="md:hidden hidden bg-green-700" id="mobile-menu">
            <div class="px-2 pt-2 pb-3 space-y-1">
                <a href="#" class="block px-3 py-2 text-white hover:bg-green-600 rounded">Home</a>
                <a href="#" class="block px-3 py-2 text-white hover:bg-green-600 rounded">Accounts</a>
                <a href="#" class="block px-3 py-2 text-white hover:bg-green-600 rounded">Transfers</a>
                <a href="#" class="block px-3 py-2 text-white hover:bg-green-600 rounded">Loans</a>
                <a href="#" class="block px-3 py-2 text-white hover:bg-green-600 rounded">Support</a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
        <!-- Welcome Banner -->
        <section class="gradient-bg text-white rounded-xl p-6 mb-8 shadow-lg">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="mb-4 md:mb-0">
                    <h2 class="text-2xl md:text-3xl font-bold mb-2">Welcome to BNA Digital Banking</h2>
                    <p class="text-green-100">Empowering agricultural growth through secure financial solutions</p>
                </div>
                <div class="flex space-x-3">
                    <button class="bg-white text-green-700 px-4 py-2 rounded-full font-semibold hover:bg-green-50 transition">
                        Open New Account
                    </button>
                    <button class="border border-white text-white px-4 py-2 rounded-full font-semibold hover:bg-green-600 transition">
                        Learn More
                    </button>
                </div>
            </div>
        </section>

        <!-- Quick Actions -->
        <section class="mb-8">
            <h3 class="text-xl font-semibold mb-4 text-gray-700">Quick Actions</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="bg-white p-4 rounded-lg shadow-sm card-hover transition cursor-pointer text-center">
                    <div class="bg-green-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i class="fas fa-exchange-alt text-green-700 text-xl"></i>
                    </div>
                    <p class="font-medium">Transfer Money</p>
                </div>
                <div class="bg-white p-4 rounded-lg shadow-sm card-hover transition cursor-pointer text-center">
                    <div class="bg-green-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i class="fas fa-qrcode text-green-700 text-xl"></i>
                    </div>
                    <p class="font-medium">Pay with QR</p>
                </div>
                <div class="bg-white p-4 rounded-lg shadow-sm card-hover transition cursor-pointer text-center">
                    <div class="bg-green-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i class="fas fa-hand-holding-usd text-green-700 text-xl"></i>
                    </div>
                    <p class="font-medium">Apply for Loan</p>
                </div>
                <div class="bg-white p-4 rounded-lg shadow-sm card-hover transition cursor-pointer text-center">
                    <div class="bg-green-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i class="fas fa-globe-africa text-green-700 text-xl"></i>
                    </div>
                    <p class="font-medium">International Transfer</p>
                </div>
            </div>
        </section>


        <!-- Account Entry Form -->
        <section class="mb-8 bg-white rounded-xl shadow-md p-6">
            <h3 class="text-xl font-semibold mb-4 text-gray-700">Enter Your Account Details</h3>
            <form class="space-y-4">
                <div>
                    <label class="block text-gray-700 mb-2">Account Number</label>
                    <input type="text" placeholder="Enter your account number" 
                           class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
                <div>
                    <label class="block text-gray-700 mb-2">Account Type</label>
                    <select class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                        <option>Select account type</option>
                        <option>0101 Account Fluent</option>
                        <option>0115 Business Account</option>
                        <option>0121 Companion Account</option>
                        <option>Agricultural Loan</option>
                    </select>
                </div>
                <div>
                    <label class="block text-gray-700 mb-2">Currency</label>
                    <select class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                        <option>TND (Tunisian Dinar)</option>
                        <option>USD (US Dollar)</option>
                        <option>EUR (Euro)</option>
                    </select>
                </div>
                <div class="pt-2">
                    <button type="submit" class="gradient-bg text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition">
                        View Account Details
                    </button>
                </div>
            </form>
            <div class="mt-6 p-4 bg-green-50 rounded-lg">
                <h4 class="font-semibold text-green-800 mb-2">Instructions:</h4>
                <ul class="list-disc pl-5 space-y-1 text-sm text-gray-700">
                    <li>Enter your full account number (or last 4 digits)</li>
                    <li>Select your account type from the dropdown</li>
                    <li>Choose your account currency</li>
                    <li>Click "View Account Details" to see your balance and make transfers</li>
                </ul>
            </div>
        </section>

        <!-- Recent Transactions -->
        <section class="mb-8">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-semibold text-gray-700">Recent Transactions</h3>
                <button class="text-green-600 hover:text-green-800 font-medium">
                    View All <i class="fas fa-chevron-right ml-1"></i>
                </button>
            </div>
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <tr class="transaction-animation hover:bg-gray-50 cursor-pointer">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jun 15, 2023</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 bg-green-100 rounded-full flex items-center justify-center">
                                            <i class="fas fa-shopping-cart text-green-600"></i>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-gray-900">AgroTech Supplies</div>
                                            <div class="text-sm text-gray-500">Payment</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-medium">-$245.50</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Completed</span>
                                </td>
                            </tr>
                            <tr class="transaction-animation hover:bg-gray-50 cursor-pointer">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jun 14, 2023</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 bg-blue-100 rounded-full flex items-center justify-center">
                                            <i class="fas fa-exchange-alt text-blue-600"></i>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-gray-900">International Transfer</div>
                                            <div class="text-sm text-gray-500">To: AgroExport Ltd.</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-medium">-$1,250.00</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Completed</span>
                                </td>
                            </tr>
                            <tr class="transaction-animation hover:bg-gray-50 cursor-pointer">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jun 12, 2023</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 bg-yellow-100 rounded-full flex items-center justify-center">
                                            <i class="fas fa-hand-holding-usd text-yellow-600"></i>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-gray-900">Loan Disbursement</div>
                                            <div class="text-sm text-gray-500">Agri-Growth Loan</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-medium">+$5,000.00</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Completed</span>
                                </td>
                            </tr>
                            <tr class="transaction-animation hover:bg-gray-50 cursor-pointer">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jun 10, 2023</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 bg-purple-100 rounded-full flex items-center justify-center">
                                            <i class="fas fa-tractor text-purple-600"></i>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-gray-900">Farm Equipment Sale</div>
                                            <div class="text-sm text-gray-500">Payment received</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-medium">+$3,780.50</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Completed</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Currency Exchange Rates -->
        <section class="mb-8 bg-white rounded-xl shadow-md p-6">
            <h3 class="text-xl font-semibold mb-4 text-gray-700">Currency Exchange Rates</h3>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Currency</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Buy (TND)</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sell (TND)</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Update</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-6 w-6 rounded-full bg-blue-100 flex items-center justify-center mr-2">
                                        <span class="text-xs font-medium">$</span>
                                    </div>
                                    <div>US Dollar (USD)</div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-green-600 font-medium">3.120</td>
                            <td class="px-6 py-4 whitespace-nowrap text-red-600 font-medium">3.150</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Today, 09:45</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-6 w-6 rounded-full bg-yellow-100 flex items-center justify-center mr-2">
                                        <span class="text-xs font-medium">€</span>
                                    </div>
                                    <div>Euro (EUR)</div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-green-600 font-medium">3.420</td>
                            <td class="px-6 py-4 whitespace-nowrap text-red-600 font-medium">3.450</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Today, 09:45</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-6 w-6 rounded-full bg-red-100 flex items-center justify-center mr-2">
                                        <span class="text-xs font-medium">£</span>
                                    </div>
                                    <div>British Pound (GBP)</div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-green-600 font-medium">4.020</td>
                            <td class="px-6 py-4 whitespace-nowrap text-red-600 font-medium">4.060</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500
